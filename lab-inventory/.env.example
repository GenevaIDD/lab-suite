# ── Frontend (Vite) — exposed to the browser, safe to be public ──
# Read at build time. In Vercel, set these per project
# (production project → prod Supabase, staging project → staging Supabase).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Environment label. Set to "staging" on the staging deploy to show the
# in-app STAGING banner. Leave unset / "production" for prod.
VITE_APP_ENV=production

# ── Server only (Vercel serverless function api/admin-users.ts) ──
# NEVER commit this and NEVER give it a VITE_ prefix — it bypasses RLS.
# Set it in the Vercel project's Environment Variables, not in this file.
# Only needed locally if you run `vercel dev` to test the invite function.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_URL=https://your-project.supabase.co
