# Copy to .vercel-staging.env (gitignored) and fill in from the STAGING
# Vercel project: Settings → General shows the Project ID; the Org/Team ID
# is in Team Settings. Used by scripts/deploy-staging.sh to target staging.
VERCEL_ORG_ID=team_or_user_id_here
VERCEL_PROJECT_ID=staging_project_id_here
